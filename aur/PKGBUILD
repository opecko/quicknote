# Maintainer: opecko <opavlat5@gmail.com>
pkgname=quicknote
pkgver=0.1.0
pkgrel=1
pkgdesc="Quick notes in the terminal"
arch=('any')
url="https://github.com/opecko/quicknote"
license=('MIT')
depends=('python' 'python-click' 'python-rich' 'python-tinydb')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('0b74be8c0e57c11cc93607bba879af0b1d117a4d7bbffa93d6aa0c62ede667e2')

build() {
  cd "$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
